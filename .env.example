# =============================================================================
# ClinAuditAI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=ClinAuditAI
APP_ENV=development          # development | staging | production
APP_DEBUG=true               # Enable debug mode (disable in production)
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=DEBUG          # DEBUG | INFO | WARNING | ERROR | CRITICAL

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=db
DB_PORT=5433
DB_NAME=clinaudit_ai
DB_USER=gg_user
DB_PASSWORD=changeme_in_production
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# -----------------------------------------------------------------------------
# AI / LLM Provider
# -----------------------------------------------------------------------------
# Which provider to use: openai | ollama | anthropic
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.0
OPENAI_REQUEST_TIMEOUT=60.0

# Ollama Configuration (local LLM — no API key needed)
# For local dev:   OLLAMA_BASE_URL=http://localhost:11434
# For Docker:      OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral-small
OLLAMA_MAX_TOKENS=2048
OLLAMA_TEMPERATURE=0.0
OLLAMA_REQUEST_TIMEOUT=120.0

# Anthropic Configuration (if using anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Vector Search (FAISS)
# -----------------------------------------------------------------------------
FAISS_INDEX_PATH=data/guidelines.index
GUIDELINES_CSV_PATH=data/guidelines.csv

# -----------------------------------------------------------------------------
# Medical Embeddings
# -----------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=NeuML/pubmedbert-base-embeddings-matryoshka
EMBEDDING_DIMENSION=768

# -----------------------------------------------------------------------------
# Patient Data
# -----------------------------------------------------------------------------
PATIENT_DATA_PATH=data/msk_valid_notes.csv

# -----------------------------------------------------------------------------
# Pipeline Settings
# -----------------------------------------------------------------------------
RETRIEVER_TOP_K=5            # Number of guideline chunks to retrieve per query
RETRIEVER_MIN_SIMILARITY=1.2 # Max L2 distance — results above this are filtered out
MAX_QUERIES_PER_DIAGNOSIS=3  # Max search queries generated per diagnosis
SCORER_MAX_GUIDELINE_CHARS=2000  # Max chars of guideline text sent to scorer

# -----------------------------------------------------------------------------
# Timeout Settings
# -----------------------------------------------------------------------------
OPENAI_REQUEST_TIMEOUT=60.0       # Seconds per LLM API call
PIPELINE_PATIENT_TIMEOUT=300.0      # Seconds per patient before timeout (5 min)
BATCH_CONCURRENCY=5                 # Patients processed in parallel (OpenAI benefits most)
