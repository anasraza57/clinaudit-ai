# =============================================================================
# MSK Clinical Audit System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=GuidelineGuard
APP_ENV=development          # development | staging | production
APP_DEBUG=true               # Enable debug mode (disable in production)
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=DEBUG          # DEBUG | INFO | WARNING | ERROR | CRITICAL

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_NAME=msk_audit
DB_USER=msk_user
DB_PASSWORD=changeme_in_production
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# -----------------------------------------------------------------------------
# AI / LLM Provider
# -----------------------------------------------------------------------------
# Which provider to use: openai | anthropic | local
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.0

# Anthropic Configuration (if using anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Vector Search (FAISS)
# -----------------------------------------------------------------------------
FAISS_INDEX_PATH=data/guidelines.index
GUIDELINES_CSV_PATH=data/guidelines.csv

# -----------------------------------------------------------------------------
# Medical Embeddings
# -----------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=NeuML/pubmedbert-base-embeddings-matryoshka
EMBEDDING_DIMENSION=768

# -----------------------------------------------------------------------------
# Patient Data
# -----------------------------------------------------------------------------
PATIENT_DATA_PATH=data/msk_valid_notes.csv

# -----------------------------------------------------------------------------
# Pipeline Settings
# -----------------------------------------------------------------------------
RETRIEVER_TOP_K=5            # Number of guideline chunks to retrieve per query
MAX_QUERIES_PER_DIAGNOSIS=3  # Max search queries generated per diagnosis
SCORER_MAX_GUIDELINE_CHARS=2000  # Max chars of guideline text sent to scorer
